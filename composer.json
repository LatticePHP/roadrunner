{
    "name": "lattice/roadrunner",
    "description": "RoadRunner integration for the LatticePHP framework",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "roadrunner",
        "application-server",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/roadrunner"
    },
    "require": {
        "php": "^8.4",
        "lattice/contracts": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\RoadRunner\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\RoadRunner\\Tests\\": "tests/"
        }
    }
}
